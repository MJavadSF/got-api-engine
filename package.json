{
  "name": "got-api-engine",
  "version": "2.1.0",
  "description": "A modular, framework-agnostic HTTP proxy engine built on got \u2014 production-grade with circuit breaker, response caching, rate limiting, request dedupe, retries with backoff, SSRF protection, metrics, and full Next.js / Node.js support.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/adapters/next.d.ts",
      "import": "./dist/adapters/next.mjs",
      "require": "./dist/adapters/next.js"
    },
    "./node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.mjs",
      "require": "./dist/adapters/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "got",
    "http",
    "proxy",
    "api",
    "nextjs",
    "react",
    "typescript",
    "fetch",
    "middleware",
    "auth",
    "retry",
    "logging",
    "zod",
    "validation",
    "circuit-breaker",
    "rate-limit",
    "cache",
    "resilience",
    "ssrf",
    "metrics",
    "dedupe",
    "observability"
  ],
  "author": {
    "name": "Mohammad Javad",
    "email": "mjavadsf72@gmail.com",
    "url": "https://github.com/MJavadSF"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MJavadSF/got-api-engine"
  },
  "homepage": "https://github.com/MJavadSF/got-api-engine#readme",
  "bugs": {
    "url": "https://github.com/MJavadSF/got-api-engine/issues"
  },
  "peerDependencies": {
    "got": ">=13.0.0",
    "next": ">=13.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "got": "^15.0.5",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
